// Ejemplo JSON Nativo

// Crear y convertir objeto a JSON
let persona = {"nombre": "Ana", "edad": 25, "activo": true};
let json = stringify(persona);
echo("JSON: " + json);

// Parsear JSON de vuelta a objeto
let parsed = parse(json);
echo("Nombre: " + parsed["nombre"] + ", Edad: " + parsed["edad"]);

// Array JSON
let numeros = [1, 2, 3];
echo("Array JSON: " + stringify(numeros));
