// Ejemplo 2: Condicionales y Bucles

let edad = 20;

// Condicionales if/else
if (edad >= 18) {
    echo("Eres mayor de edad");
} else {
    echo("Eres menor de edad");
}

// Bucle for básico
echo("Contando del 1 al 3:");
for (let i = 1; i <= 3; i++) {
    echo("Número: " + i);
}

// Bucle while con break
let contador = 0;
while (true) {
    contador++;
    if (contador > 2) {
        break;
    }
    echo("Contador: " + contador);
}
