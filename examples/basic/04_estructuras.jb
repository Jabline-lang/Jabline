// Ejemplo 4: Estructuras

// Definir una estructura con tipos explícitos
struct Persona {
    nombre: string,
    edad: int,
    activo: bool
}

// Crear instancias especificando todos los campos
let p = Persona {
    nombre: "Carlos",
    edad: 28,
    activo: true
};

echo("Nombre: " + p.nombre);
echo("Edad: " + p.edad);
echo("Activo: " + p.activo);
